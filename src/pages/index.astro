---
import "../styles/global.css";
import { faqData } from "../data/faqData.js";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeNavigation from "../components/home/HomeNavigation.jsx";
import HeroSection from "../components/home/HeroSection.jsx";
import PhilosophySection from "../components/home/PhilosophySection.jsx";
import ReferencesSection from "../components/home/ReferencesSection.jsx";
import AboutSection from "../components/home/AboutSection.jsx";
import PricingSection from "../components/home/PricingSection.jsx";
import FAQSection from "../components/home/FAQSection.jsx";
import ContactSection from "../components/home/ContactSection.jsx";

const pageTitle = "Webdesign für Ärzte & Praxen in Berlin, Potsdam & Umland | Gilbert Webdesign";
const pageDescription =
  "Professionelles Webdesign für Ärzte, Physiotherapeuten & Studios in Berlin, Potsdam und Umland. Modern, performant & SEO-optimiert. Jetzt kostenlose Erstberatung vereinbaren!";
const canonicalUrl = "https://gilbert-webdesign.de/";
const profileImageUrl =
  "https://gilbert-webdesign.de/webdesigner-berlin-praxen-salons-laurenz-gilbert.webp";
const organizationId = "https://gilbert-webdesign.de/#organization";
const personId = "https://gilbert-webdesign.de/#person";
const websiteId = "https://gilbert-webdesign.de/#website";
const localBusinessId = "https://gilbert-webdesign.de/#localbusiness";
const faqPageId = "https://gilbert-webdesign.de/#faq";
const offerCatalogId = "https://gilbert-webdesign.de/#offer-catalog";
const onePagerOfferId = "https://gilbert-webdesign.de/#offer-onepager";
const multiPageOfferId = "https://gilbert-webdesign.de/#offer-multipage";
const onePagerServiceId = "https://gilbert-webdesign.de/#service-onepager";
const multiPageServiceId = "https://gilbert-webdesign.de/#service-multipage";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": faqPageId,
      mainEntity: faqData.map(faq => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer
        }
      }))
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: "https://gilbert-webdesign.de/",
      name: "Gilbert Webdesign",
      inLanguage: "de-DE",
      publisher: {
        "@id": organizationId,
      },
    },
    {
      "@type": "Organization",
      "@id": organizationId,
      name: "Gilbert Webdesign",
      url: "https://gilbert-webdesign.de/",
      sameAs: [
        "https://g.page/r/CQUQY71XvWNJEAE",
        "https://www.linkedin.com/in/laurenz-gilbert-687181242/",
        "https://github.com/DieserLaurenz",
      ],
      logo: profileImageUrl,
      description: pageDescription,
      email: "kontakt@gilbert-webdesign.de",
      telephone: "+49 176 55156501",
      founder: {
        "@id": personId,
      },
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        telephone: "+49 176 55156501",
        email: "kontakt@gilbert-webdesign.de",
        areaServed: "DE",
        availableLanguage: ["de", "en"],
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
      makesOffer: [
        { "@id": onePagerOfferId },
        { "@id": multiPageOfferId },
      ],
    },
    {
      "@type": "Person",
      "@id": personId,
      name: "Laurenz Cornelius Gilbert",
      jobTitle: "Webdesigner und Entwickler",
      url: "https://gilbert-webdesign.de/",
      image: profileImageUrl,
      email: "kontakt@gilbert-webdesign.de",
      telephone: "+49 176 55156501",
      worksFor: {
        "@id": organizationId,
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
      knowsAbout: [
        "Webdesign für Ärzte",
        "Webdesign für Physiotherapie-Praxen",
        "Webdesign für Wellness-Studios",
        "Technisches SEO",
        "Astro",
        "React",
      ],
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": localBusinessId,
      name: "Gilbert Webdesign",
      url: "https://gilbert-webdesign.de/",
      image: profileImageUrl,
      logo: profileImageUrl,
      description: pageDescription,
      email: "kontakt@gilbert-webdesign.de",
      telephone: "+49 176 55156501",
      areaServed: [
        {
          "@type": "City",
          name: "Berlin",
        },
        {
          "@type": "City",
          name: "Potsdam",
        },
        "Umland",
      ],
      availableLanguage: ["de", "en"],
      serviceType: [
        "Webdesign für Ärzte",
        "Webdesign für Physiotherapie-Praxen",
        "Webdesign für Salons und Studios",
        "Technisches SEO",
      ],
      priceRange: "€1.290 - €2.290",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
      founder: {
        "@id": personId,
      },
      hasOfferCatalog: {
        "@id": offerCatalogId,
      },
      makesOffer: [
        { "@id": onePagerOfferId },
        { "@id": multiPageOfferId },
      ],
    },
    {
      "@type": "OfferCatalog",
      "@id": offerCatalogId,
      name: "Leistungspakete",
      itemListElement: [
        { "@id": onePagerOfferId },
        { "@id": multiPageOfferId },
      ],
    },
    {
      "@type": "Service",
      "@id": onePagerServiceId,
      name: "Digitale Visitenkarte (One-Pager)",
      provider: {
        "@id": organizationId,
      },
      areaServed: ["Berlin", "Potsdam", "Umland"],
      audience: {
        "@type": "BusinessAudience",
        audienceType: "Arztpraxen, Physiotherapie-Praxen und Studios",
      },
      serviceType: "One-Pager Webdesign",
      offers: {
        "@id": onePagerOfferId,
      },
    },
    {
      "@type": "Offer",
      "@id": onePagerOfferId,
      itemOffered: {
        "@id": onePagerServiceId,
      },
      price: "1290",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: "https://gilbert-webdesign.de/#leistungen",
      category: "B2B Webdesign",
      eligibleCustomerType: "https://schema.org/BusinessAudience",
    },
    {
      "@type": "Service",
      "@id": multiPageServiceId,
      name: "Umfassende Praxis-Website (Multi-Pager)",
      provider: {
        "@id": organizationId,
      },
      areaServed: ["Berlin", "Potsdam", "Umland"],
      audience: {
        "@type": "BusinessAudience",
        audienceType: "Arztpraxen, Physiotherapie-Praxen und Studios",
      },
      serviceType: "Multi-Page Webdesign",
      offers: {
        "@id": multiPageOfferId,
      },
    },
    {
      "@type": "Offer",
      "@id": multiPageOfferId,
      itemOffered: {
        "@id": multiPageServiceId,
      },
      price: "2290",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: "https://gilbert-webdesign.de/#leistungen",
      category: "B2B Webdesign",
      eligibleCustomerType: "https://schema.org/BusinessAudience",
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  ogImage={profileImageUrl}
  ogImageAlt="Laurenz Gilbert von Gilbert Webdesign für Berlin, Potsdam und Umland"
  twitterCard="summary_large_image"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans selection:bg-blue-100 selection:text-blue-900 overflow-x-hidden">
    <HomeNavigation />
    <main>
      <HeroSection />
      <PhilosophySection />
      <ReferencesSection />
      <AboutSection />
      <PricingSection />
    </main>
  </div>
  <FAQSection client:visible />
  <ContactSection client:visible />
</BaseLayout>
