---
import "../styles/global.css";
import { faqData } from "../data/faqData.js";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeStaticSections from "../components/home/HomeStaticSections.jsx";
import FAQSection from "../components/home/FAQSection.jsx";
import ContactSection from "../components/home/ContactSection.jsx";

const pageTitle = "Webdesign für Ärzte & Praxen in Berlin | Gilbert Webdesign";
const pageDescription =
  "Professionelles Webdesign für Ärzte, Physiotherapeuten & Studios in Berlin. Modern, performant & SEO-optimiert. Jetzt kostenlose Erstberatung vereinbaren!";
const canonicalUrl = "https://gilbert-webdesign.de/";
const profileImageUrl =
  "https://gilbert-webdesign.de/webdesigner-berlin-praxen-salons-laurenz-gilbert.webp";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://gilbert-webdesign.de/#faq",
      mainEntity: faqData.map(faq => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer
        }
      }))
    },
    {
      "@type": "WebSite",
      "@id": "https://gilbert-webdesign.de/#website",
      url: "https://gilbert-webdesign.de/",
      name: "Gilbert Webdesign",
      inLanguage: "de-DE",
      publisher: {
        "@id": "https://gilbert-webdesign.de/#organization",
      },
    },
    {
      "@type": "Organization",
      "@id": "https://gilbert-webdesign.de/#organization",
      name: "Gilbert Webdesign",
      url: "https://gilbert-webdesign.de/",
      sameAs: ["https://g.page/r/CQUQY71XvWNJEAE"],
      logo: profileImageUrl,
      description: pageDescription,
      email: "kontakt@gilbert-webdesign.de",
      telephone: "+49 176 55156501",
      founder: {
        "@type": "Person",
        name: "Laurenz Cornelius Gilbert",
      },
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        telephone: "+49 176 55156501",
        email: "kontakt@gilbert-webdesign.de",
        areaServed: "DE",
        availableLanguage: ["de", "en"],
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://gilbert-webdesign.de/#localbusiness",
      name: "Gilbert Webdesign",
      url: "https://gilbert-webdesign.de/",
      image: profileImageUrl,
      logo: profileImageUrl,
      description: pageDescription,
      email: "kontakt@gilbert-webdesign.de",
      telephone: "+49 176 55156501",
      areaServed: {
        "@type": "City",
        name: "Berlin",
      },
      availableLanguage: ["de", "en"],
      serviceType: [
        "Webdesign fuer Aerzte",
        "Webdesign fuer Physiotherapie-Praxen",
        "Webdesign fuer Salons und Studios",
        "Technisches SEO",
      ],
      priceRange: "EUR",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  ogImage={profileImageUrl}
  twitterCard="summary_large_image"
  structuredData={structuredData}
>
  <HomeStaticSections />
  <FAQSection client:visible />
  <ContactSection client:visible />
</BaseLayout>
