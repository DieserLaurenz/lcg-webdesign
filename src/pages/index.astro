---
import AgencySite from "../../App.jsx";
import "../styles/global.css";

const pageTitle = "Webdesign für Ärzte & Praxen in Berlin | LCG Webdesign";
const pageDescription =
  "Professionelles Webdesign für Ärzte, Physiotherapeuten & Studios in Berlin. Modern, performant & SEO-optimiert. Jetzt kostenlose Erstberatung vereinbaren!";
const canonicalUrl = "https://lcg-webdesign.de/";
const profileImageUrl =
  "https://lcg-webdesign.de/webdesigner-berlin-praxen-salons-laurenz-gilbert.webp";

const faqData = [
  {
    question: "Was kostet eine professionelle Website für meine Praxis oder mein Studio?",
    answer: "Eine kompakte Digitale Visitenkarte (One-Pager) kostet 1.290 € netto (zzgl. MwSt.). Eine umfassende Praxis-Website mit mehreren Unterseiten kostet 2.290 € netto (zzgl. MwSt.). Alle Preise richten sich ausschließlich an Gewerbetreibende (B2B)."
  },
  {
    question: "Wie läuft ein Website-Projekt mit Ihnen konkret ab?",
    answer: "Nach einem unverbindlichen Erstgespräch erhalten Sie ein individuelles Angebot. Bei Auftragserteilung starten wir mit 50 % Anzahlung. Sie liefern mir Texte, Bilder und Ihr Logo. Ich entwickle Ihre Website und stelle sie auf einer Testumgebung bereit. Nach Ihrer Freigabe und Zahlung der zweiten Rate geht die Seite live."
  },
  {
    question: "Wie lange dauert die Erstellung einer neuen Praxis-Website?",
    answer: "Für einen One-Pager plane ich in der Regel 2 bis 3 Wochen ab Erhalt aller Materialien. Bei einer umfangreicheren Multi-Page-Website sollten Sie etwa 4 bis 6 Wochen einplanen."
  },
  {
    question: "Wem gehört die fertige Website und wo wird sie gehostet?",
    answer: "Die Website gehört Ihnen. Mit vollständiger Bezahlung erhalten Sie die unbeschränkten Nutzungsrechte am gesamten Code und Design. Das Hosting läuft über Ihren eigenen Account bei Cloudflare Pages."
  },
  {
    question: "Garantieren Sie ein Google-Ranking?",
    answer: "Ich übernehme die technische On-Page-Optimierung nach aktuellen Standards. Eine Platzierungsgarantie gebe ich bewusst nicht – das wäre unseriös, da Rankings von Google-Algorithmen abhängen, die niemand kontrolliert."
  },
  {
    question: "Ist meine neue Website technisch DSGVO-konform?",
    answer: "Ich setze das technische Fundament für DSGVO-Konformität um: SSL-Verschlüsselung, lokales Hosting von Schriftarten und vorbereitete Seiten für Impressum sowie Datenschutzerklärung. Die rechtlichen Texte selbst müssen Sie von einem spezialisierten Anwalt erstellen lassen."
  },
  {
    question: "Können Patienten direkt über meine Website Termine buchen?",
    answer: "Ja. Ich verknüpfe Ihre Website mit Ihrem bestehenden Buchungssystem – etwa Doctolib, Jameda oder Treatwell. Patienten gelangen mit einem Klick zur Terminbuchung."
  },
  {
    question: "Gibt es laufende Kosten nach der Fertigstellung?",
    answer: "Nein, es gibt keine verpflichtenden laufenden Kosten an mich. Das Hosting über Cloudflare Pages ist für die meisten Praxen kostenlos. Optional biete ich einen technischen Support für 59 € netto pro Monat an."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://lcg-webdesign.de/#faq",
      mainEntity: faqData.map(faq => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer
        }
      }))
    },
    {
      "@type": "WebSite",
      "@id": "https://lcg-webdesign.de/#website",
      url: "https://lcg-webdesign.de/",
      name: "LCG Webdesign",
      inLanguage: "de-DE",
      publisher: {
        "@id": "https://lcg-webdesign.de/#organization",
      },
    },
    {
      "@type": "Organization",
      "@id": "https://lcg-webdesign.de/#organization",
      name: "LCG Webdesign",
      url: "https://lcg-webdesign.de/",
      sameAs: ["https://g.page/r/CQUQY71XvWNJEAE"],
      logo: profileImageUrl,
      description: pageDescription,
      email: "kontakt@lcg-webdesign.de",
      telephone: "+49 176 55156501",
      founder: {
        "@type": "Person",
        name: "Laurenz Cornelius Gilbert",
      },
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        telephone: "+49 176 55156501",
        email: "kontakt@lcg-webdesign.de",
        areaServed: "DE",
        availableLanguage: ["de", "en"],
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://lcg-webdesign.de/#localbusiness",
      name: "LCG Webdesign",
      url: "https://lcg-webdesign.de/",
      image: profileImageUrl,
      logo: profileImageUrl,
      description: pageDescription,
      email: "kontakt@lcg-webdesign.de",
      telephone: "+49 176 55156501",
      areaServed: {
        "@type": "City",
        name: "Berlin",
      },
      availableLanguage: ["de", "en"],
      serviceType: [
        "Webdesign fuer Aerzte",
        "Webdesign fuer Physiotherapie-Praxen",
        "Webdesign fuer Salons und Studios",
        "Technisches SEO",
      ],
      priceRange: "EUR",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Argentinische Allee 93",
        postalCode: "14163",
        addressLocality: "Berlin",
        addressCountry: "DE",
      },
    },
  ],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="LCG Webdesign" />
    <meta
      property="og:image"
      content={profileImageUrl}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <AgencySite client:load />
  </body>
</html>
