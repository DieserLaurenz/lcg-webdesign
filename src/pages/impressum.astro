---
import ImpressumPage from "../components/ImpressumPage.jsx";
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Impressum | Gilbert Webdesign";
const pageDescription =
  "Impressum von Gilbert Webdesign mit den gesetzlich erforderlichen Angaben und Kontaktinformationen.";
const canonicalUrl = "https://gilbert-webdesign.de/impressum/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  twitterCard="summary"
>
  <ImpressumPage client:load />
</BaseLayout>
