---
import AGBPage from "../components/AGBPage.jsx";
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "AGB | Gilbert Webdesign";
const pageDescription =
  "Allgemeine Geschäftsbedingungen (AGB) von Gilbert Webdesign für Leistungen im Bereich Webdesign und Entwicklung.";
const canonicalUrl = "https://gilbert-webdesign.de/agb/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  twitterCard="summary"
>
  <AGBPage />
</BaseLayout>
