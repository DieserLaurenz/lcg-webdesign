---
import DatenschutzPage from "../components/DatenschutzPage.jsx";
import "../styles/global.css";

const pageTitle = "Datenschutzerklärung | LCG Webdesign";
const pageDescription =
  "Datenschutzerklärung von LCG Webdesign mit Informationen zur Verarbeitung personenbezogener Daten.";
const canonicalUrl = "https://lcg-webdesign.de/datenschutz/";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="LCG Webdesign" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <DatenschutzPage client:load />
  </body>
</html>
